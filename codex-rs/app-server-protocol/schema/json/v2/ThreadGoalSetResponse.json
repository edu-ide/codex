{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ThreadGoal": {
      "properties": {
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "loopHistory": {
          "items": {
            "$ref": "#/definitions/ThreadGoalLoopHistoryEntry"
          },
          "type": "array"
        },
        "loopState": {
          "anyOf": [
            {
              "$ref": "#/definitions/ThreadGoalLoopState"
            },
            {
              "type": "null"
            }
          ]
        },
        "objective": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/ThreadGoalStatus"
        },
        "superloopEnabled": {
          "default": false,
          "type": "boolean"
        },
        "threadId": {
          "type": "string"
        },
        "timeUsedSeconds": {
          "format": "int64",
          "type": "integer"
        },
        "tokenBudget": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "tokensUsed": {
          "format": "int64",
          "type": "integer"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "createdAt",
        "loopHistory",
        "objective",
        "status",
        "threadId",
        "timeUsedSeconds",
        "tokensUsed",
        "updatedAt"
      ],
      "type": "object"
    },
    "ThreadGoalLoopHistoryEntry": {
      "properties": {
        "completedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "cycleNumber": {
          "format": "int64",
          "type": "integer"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/definitions/ThreadGoalLoopPhase"
        },
        "startedAt": {
          "format": "int64",
          "type": "integer"
        },
        "status": {
          "$ref": "#/definitions/ThreadGoalLoopStatus"
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "cycleNumber",
        "id",
        "phase",
        "startedAt",
        "status",
        "summary",
        "title",
        "updatedAt"
      ],
      "type": "object"
    },
    "ThreadGoalLoopPhase": {
      "enum": [
        "knowledgeLoop",
        "kairosLoop",
        "superLoop",
        "planLoop",
        "brainResearchLoop",
        "codebaseResearchLoop",
        "agentSkillResearchLoop",
        "webResearchLoop",
        "researchLoop",
        "decisionLoop",
        "wikiLoop",
        "logLoop",
        "improvementLoop",
        "cleanupLoop",
        "executionLoop",
        "verificationLoop",
        "contextInjection"
      ],
      "type": "string"
    },
    "ThreadGoalLoopState": {
      "properties": {
        "cycleNumber": {
          "format": "int64",
          "type": "integer"
        },
        "phase": {
          "$ref": "#/definitions/ThreadGoalLoopPhase"
        },
        "status": {
          "$ref": "#/definitions/ThreadGoalLoopStatus"
        },
        "summary": {
          "type": "string"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "cycleNumber",
        "phase",
        "status",
        "summary",
        "updatedAt"
      ],
      "type": "object"
    },
    "ThreadGoalLoopStatus": {
      "enum": [
        "inProgress",
        "completed",
        "failed"
      ],
      "type": "string"
    },
    "ThreadGoalStatus": {
      "enum": [
        "active",
        "paused",
        "blocked",
        "usageLimited",
        "budgetLimited",
        "complete"
      ],
      "type": "string"
    }
  },
  "properties": {
    "goal": {
      "$ref": "#/definitions/ThreadGoal"
    }
  },
  "required": [
    "goal"
  ],
  "title": "ThreadGoalSetResponse",
  "type": "object"
}